CC = clang
AR = llvm-ar
ROOT = `{realpath "$PWD/.."}
CFLAGS = -g -fsanitize=address -O0 \
				 -Wall -Werror -Wextra -Wpedantic \
				 -I$ROOT/include/
DEPFILES = `{/bin/sh -c 'find . -maxdepth 1 -name "*.d"'}

all:V: chat-server server client

# Add /dev/null because else if $DEPFILES is empty, cat will block on stdin
<|cat $DEPFILES /dev/null

chat-server: chat-server.o connections.o
	$CC $CFLAGS $prereq -o $target

server: server.o chris-tcp.o message.o connections.o
	$CC $CFLAGS $prereq -o $target

client: client.o chris-tcp.o message.o
	$CC $CFLAGS $prereq -o $target

%.o: $ROOT/bin/%.c
	$CC $CFLAGS \
		-MT $target -MMD -MP -MF $stem.d \
		-c $ROOT/bin/$stem.c -o $target

%.o: $ROOT/src/%.c
	$CC $CFLAGS \
		-MT $target -MMD -MP -MF $stem.d \
		-c $ROOT/src/$stem.c -o $target

clean:V:
	rm -f *.o *.d chat-server client server

